              <strong>Adresse</strong>
              <span>Maison des syndicats<br />26 rue Francis Combe<br />75000 Paris</span>
            </div>
          </div>
          <div class="contact-info-item animate-in">
            <div class="contact-info-icon" aria-hidden="true">🕙</div>
            <div class="contact-info-text">
              <strong>Horaires du congrès</strong>
              <span>Vendredi 26 juin 2026<br />10h00 – 17h00</span>
            </div>
          </div>
          <div class="contact-info-item animate-in">
            <div class="contact-info-icon" aria-hidden="true">🌐</div>
            <div class="contact-info-text">
              <strong>Site confédéral</strong>
              <span><a href="https://www.cftc.fr" target="_blank" rel="noopener" style="color:var(--blue-mid);">www.cftc.fr</a></span>
            </div>
          </div>
        </div>

        <!-- Formulaire -->
        <div class="contact-form animate-in">
          <form id="contact-form" novalidate aria-label="Formulaire de contact">
            <div class="form-group">
              <label class="form-label" for="name">Nom complet *</label>
              <input class="form-input" type="text" id="name" name="name" placeholder="Prénom Nom" required autocomplete="name" />
            </div>
            <div class="form-group">
              <label class="form-label" for="email">Adresse email *</label>
              <input class="form-input" type="email" id="email" name="email" placeholder="prenom.nom@exemple.fr" required autocomplete="email" />
            </div>
            <div class="form-group">
              <label class="form-label" for="syndicat">Syndicat / Organisation</label>
              <input class="form-input" type="text" id="syndicat" name="syndicat" placeholder="Votre syndicat ou organisation" />
            </div>
            <div class="form-group">
              <label class="form-label" for="sujet">Sujet *</label>
              <select class="form-select" id="sujet" name="sujet" required>
                <option value="">Choisir un sujet…</option>
                <option>Inscription / Mandat de délégué</option>
                <option>Candidature au Conseil</option>
                <option>Documents du congrès</option>
                <option>Information générale</option>
                <option>Autre</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label" for="message">Message *</label>
              <textarea class="form-textarea" id="message" name="message" placeholder="Votre message…" required></textarea>
            </div>
            <button type="submit" class="form-submit">
              Envoyer le message ✉️
            </button>
          </form>

          <div id="form-success" class="form-success" role="alert" aria-live="polite">
            <div style="font-size:2.5rem; margin-bottom:0.75rem;">✅</div>
            <div style="font-size:1.1rem; margin-bottom:0.5rem;">Message envoyé !</div>
            <div style="font-size:0.875rem; color:var(--gray-text); font-weight:400;">
              L'équipe d'organisation vous répondra dans les meilleurs délais à l'adresse indiquée.
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

